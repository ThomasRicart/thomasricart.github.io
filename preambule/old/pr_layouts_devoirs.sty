\newcounter{nexods}
\setcounter{nexods}{0}
\newcommand{\exods}[1]{
\refstepcounter{nexods}
  \ifthenelse{#1 = 1}{%
    % Si le paramètre est égal à 1
	\fbox{\textbf{\texttt{Exercice  \thenexods \, $\blacktriangleright$}}} \hfill \fbox{\qquad\qquad \texttt{\textbf{/1 point}\;}}
  }{%
    \ifthenelse{#1 > 1}{%
      % Si le paramètre est égal à 2
	\fbox{\textbf{\texttt{Exercice  \thenexods \, $\blacktriangleright$}}} \hfill \fbox{\qquad\qquad \texttt{\textbf{/#1 points}}}
    }{%
      % Sinon
	\fbox{\textbf{\texttt{Exercice  \thenexods \, $\blacktriangleright$}}} \par
    }%
  }%
  \rule{0.96\linewidth}{1pt}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%ùù
\newcounter{nexodsd}
\setcounter{nexodsd}{0}

% Commande pour créer un exercice avec champ de note éditable
\newcommand{\exodst}[1]{%
\refstepcounter{nexodsd}%
\edef\currentexo{\arabic{nexodsd}}%
  \ifthenelse{#1 = 1}{%
    % Si le paramètre est égal à 1
    \fbox{\textbf{\texttt{Exercice \currentexo \, $\blacktriangleright$}}} 
    \hfill 
    \fbox{\TextField[name=note\currentexo, charsize=8pt, width=1.cm, bordercolor={0 0 0}, backgroundcolor={1 1 1}, keystroke={AFNumber_Keystroke(2, 0, 0, 0, "", true);}]{} \texttt{\textbf{/1 point}\;}}%
  }{%
    \ifthenelse{#1 > 1}{%
      % Si le paramètre est supérieur à 1
      \fbox{\textbf{\texttt{Exercice \currentexo \, $\blacktriangleright$}}} 
      \hfill 
      \fbox{\TextField[name=note\currentexo, charsize=8pt, width=1.cm, bordercolor={0 0 0}, backgroundcolor={1 1 1}, keystroke={AFNumber_Keystroke(2, 0, 0, 0, "", true);}]{} \texttt{\textbf{/#1 points}}}%
    }{%
      % Sinon (pas de note)
      \fbox{\textbf{\texttt{Exercice \currentexo \, $\blacktriangleright$}}} \par
    }%
  }%
  \par\nointerlineskip
  \rule{0.96\linewidth}{1pt}%
}



