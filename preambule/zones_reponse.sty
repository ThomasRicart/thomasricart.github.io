\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{\packagepath/zones_reponse}

\RequirePackage{tcolorbox}

% Commande : \reponse[largeur]{hauteur}
\newcommand{\reponse}[2][\linewidth]{
    %\begin{center}
    \begin{tcolorbox}[
        width=#1\linewidth,
        height=#2cm,
        colback=lightgray!20,
        colframe=black,
        rounded corners,
        enhanced % permet des réglages avancés si besoin
    ]
    \end{tcolorbox}
    %\end{center}
}

