% Commande pour réponse courte en ligne (Style blocvisible)
% Usage : \reponseLigne[largeur]{contenu}
\newtcbox{\boxstyleLigne}{
    on line,                % Indispensable pour rester dans le texte
    arc=2pt,                % Coins arrondis
    outer arc=2pt,
    colback=gray!10,        % Fond gris identique à blocvisible
    colframe=black,         % Bordure noire
    boxrule=0.5pt,          % Épaisseur de bordure identique
    left=2pt, right=2pt, top=1pt, bottom=1pt, % Marges internes réduites
    before upper=\strut     % Assure une hauteur constante
}

\newcommand{\reponseLigne}[2][3cm]{%
    \ifdefstring{\visibleornot}{visible}{%
        % Si visible : on affiche le texte dans la petite box arrondie
        \boxstyleLigne{#2}%
    }{%
        % Si caché : on affiche un cadre vide arrondi de la largeur demandée
        \boxstyleLigne{\makebox[#1]{\vphantom{#2}}}%
    }%
}


\NewEnviron{blocvisiblex}[2][]{%
    % #1 = Options tcolorbox (ex: height=4cm)
    % #2 = Contenu pour la version ÉLÈVE (ex: texte à trous ou vide)
    % \BODY = Contenu pour la version CORRIGÉE (entre begin et end)
    
    \ifdefstring{\visibleornot}{visible}%
    {% --- MODE CORRECTION (PROF) ---
        \begin{tcolorbox}[
            enhanced, breakable,
            #1cm % On applique les options de style/taille
        ]
            \BODY % On affiche ce qui est écrit à l'intérieur de l'environnement
        \end{tcolorbox}
    }%
    {% --- MODE SUJET (ÉLÈVE) ---
        \begin{tcolorbox}[
            enhanced, breakable,
            #1cm % On garde la même géométrie
        ]
            #2 % On affiche le texte spécifique à l'élève (ou rien)
        \end{tcolorbox}
    }%
}

\newcommand{\trou}[1]{%
    \IfStrEq{\visibleornot}{visible}{#1}{...........}%
}

