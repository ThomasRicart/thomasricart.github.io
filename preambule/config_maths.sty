%\newtheorem{exemple}{Exemple}[section]

% --- Configuration de numprint ---
\addtolength{\jot}{2mm} % Espacement plus large entre les lignes de align*

\newcommand{\oo}[2]{\bigl] \, #1 \, ; #2 \,\bigl[ }
\newcommand{\fo}[2]{\bigl[ \, #1 \, ; #2 \,\bigl[ }
\newcommand{\of}[2]{\bigl] \, #1 \, ; #2 \,\bigl] }
\newcommand{\ff}[2]{\bigl[ \, #1 \, ; #2 \,\bigl] }


\RequirePackage{mleftright}
\newcommand{\interv}[2]{\mleft[ #1 \,;\, #2 \mright]}

