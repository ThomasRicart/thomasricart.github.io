# --- CELLULE 1 : IMPORT ET DONNÉES ---
import random

equipe = [
    {'nom': 'Aethelgard', 'pv': 120, 'force': 10, 'agilite': 5, 'armure': 15},
    {'nom': 'Slythe', 'pv': 70, 'force': 25, 'agilite': 45, 'armure': 2},
    {'nom': 'Valeria', 'pv': 100, 'force': 18, 'agilite': 20, 'armure': 10},
    {'nom': 'Grognar', 'pv': 150, 'force': 22, 'agilite': 10, 'armure': 5}
]

# --- CELLULE 2 : QUESTION 1 (Score) ---
def calculer_score(guerrier):
    # Somme simple des caractéristiques [cite: 132]
    return guerrier['pv'] + guerrier['force'] + guerrier['agilite'] + guerrier['armure']

# Test : Affiche 150
print(f"Score Aethelgard : {calculer_score(equipe[0])}")

# --- CELLULE 3 : QUESTION 2 (Création) ---
def creer_guerrier(equipe_ref=None):
    if equipe_ref is None:
        equipe_ref = []
    
    nom = input("Nom : ")
    pv = int(input("PV : "))
    force = int(input("Force : "))
    agilite = int(input("Agilité : "))
    armure = int(input("Armure : "))
    
    nouveau = {'nom': nom, 'pv': pv, 'force': force, 'agilite': agilite, 'armure': armure}
    equipe_ref.append(nouveau)
    return equipe_ref

# --- CELLULE 4 : QUESTION 3 (Tri par Insertion - LP08) ---
def trier_guerriers(equipe_a_trier):
    n = len(equipe_a_trier)
    for i in range(1, n):
        k = i
        # On trie par ordre décroissant de score total [cite: 11, 98]
        while k > 0 and calculer_score(equipe_a_trier[k]) > calculer_score(equipe_a_trier[k-1]):
            equipe_a_trier[k], equipe_a_trier[k-1] = equipe_a_trier[k-1], equipe_a_trier[k]
            k = k - 1

# --- CELLULE 5 : QUESTION 4 (Attaque) ---
def attaquer(attaquant, defenseur):
    print(f"⚔️ {attaquant['nom']} attaque {defenseur['nom']}...")
    
    # Logique d'esquive (Agilité vs 1-50)
    if defenseur['agilite'] > random.randint(1, 50):
        print(f"💨 {defenseur['nom']} a esquivé !")
    else:
        # Dégâts = Force - Armure (Min 0)
        degats = max(0, attaquant['force'] - defenseur['armure'])
        defenseur['pv'] -= degats
        print(f"💥 {degats} dégâts ! (PV restants de {defenseur['nom']} : {max(0, defenseur['pv'])})")

# --- CELLULE 6 : QUESTION 5 & 6 (Bataille d'armée) ---
def combat_equipe(equipe1, equipe2):
    # Tri préalable des équipes par puissance [cite: 141, 143]
    trier_guerriers(equipe1)
    trier_guerriers(equipe2)
    
    i, j = 0, 0 # Indices des combattants actuels
    while i < len(equipe1) and j < len(equipe2):
        g1 = equipe1[i]
        g2 = equipe2[j]
        print(f"\n--- DUEL : {g1['nom']} vs {g2['nom']} ---")
        
        # Duel à mort
        while g1['pv'] > 0 and g2['pv'] > 0:
            # Qui commence ?
            if random.choice([True, False]):
                attaquer(g1, g2)
                if g2['pv'] > 0: attaquer(g2, g1)
            else:
                attaquer(g2, g1)
                if g1['pv'] > 0: attaquer(g1, g2)
        
        # On passe au guerrier suivant si l'un meurt
        if g1['pv'] <= 0:
            print(f"💀 {g1['nom']} est tombé.")
            i += 1
        if g2['pv'] <= 0:
            print(f"💀 {g2['nom']} est vaincu.")
            j += 1

    # Résultat final
    if i < len(equipe1):
        print("\n🏆 VICTOIRE DES GUERRIERS !")
    else:
        print("\n💀 TOUS LES GUERRIERS SONT MORTS...")